{
  "name": "agent-hub",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "vue-demi"]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "backend": "cd backend && uvicorn app.main:app --reload --port 8000",
    "dev:full": "concurrently -k \"pnpm backend\" \"pnpm dev\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cookie-session": "^2.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "element-plus": "^2.9.1",
    "@element-plus/icons-vue": "^2.3.1",
    "markdown-it": "^14.1.0",
    "highlight.js": "^11.10.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^9.1.2",
    "vite": "^5.2.8",
    "typescript": "^5.4.0",
    "@types/markdown-it": "^14.1.2"
  }
}
