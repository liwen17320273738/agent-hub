# === Database ===
DATABASE_URL=postgresql+asyncpg://agenthub:agenthub@localhost:5432/agenthub

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Security ===
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# === CORS ===
CORS_ORIGINS=["http://localhost:5200","http://127.0.0.1:5200"]

# === LLM Provider Keys (配置哪个用哪个) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
ZHIPU_API_KEY=
QWEN_API_KEY=

# === Default LLM (兜底) ===
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=deepseek-chat
# Comma-separated hosts allowed when LLM_API_URL points at local OpenAI-compat (e.g. Ollama).
# LLM_ALLOWED_HOSTS=localhost,127.0.0.1

# 可选兼容写法：如果公司内部的 gamma / OpenClaw 部署只提供 ANTHROPIC_* 变量，
# backend/app/config.py 会自动把它们映射到本项目内部使用的 LLM_*。
# 二选一即可：已设置 LLM_* 时，会优先使用 LLM_*。
# ANTHROPIC_BASE_URL=http://192.168.130.230:1234
# ANTHROPIC_AUTH_TOKEN=ddd
# ANTHROPIC_MODEL=google/gemma-4-26b-a4b
# ANTHROPIC_DEFAULT_HAIKU_MODEL=google/gemma-4-26b-a4b
# ANTHROPIC_DEFAULT_SONNET_MODEL=google/gemma-4-26b-a4b
# ANTHROPIC_DEFAULT_OPUS_MODEL=google/gemma-4-26b-a4b

# === Pipeline ===
PIPELINE_API_KEY=

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=60

# === Model Cache ===
MODEL_CACHE_TTL_SECONDS=600

# === Executor ===
# Comma-separated list of directories the executor is allowed to work in
EXECUTOR_ALLOWED_DIRS=

# === Project Binding (git clone allowlist) ===
# Comma-separated hostnames allowed for `repo_url`. SSRF / arbitrary-host clones rejected.
GIT_ALLOWED_HOSTS=github.com,gitee.com,gitlab.com,bitbucket.org,codeup.aliyun.com

# === Sandbox isolation ===
# When true AND `docker` CLI works, bash tool runs inside a fresh container with
# --network none --read-only --cap-drop ALL. Falls back to strict subprocess otherwise.
SANDBOX_USE_DOCKER=false
SANDBOX_DOCKER_IMAGE=agent-hub/sandbox:latest
SANDBOX_DOCKER_NETWORK=none
SANDBOX_DOCKER_MEMORY=1g
SANDBOX_DOCKER_CPUS=1
SANDBOX_DOCKER_TIMEOUT=1800
SANDBOX_STRICT_BASH=true

# === Long-task budgets ===
PHASE_TIMEOUT_SECONDS=1800
PHASE_MAX_TIMEOUT_SECONDS=7200

# === Browser tool (Playwright) ===
# Install: pip install playwright && playwright install chromium
BROWSER_ENABLED=true
BROWSER_MAX_PAGES=5
BROWSER_DEFAULT_TIMEOUT_MS=30000

# === Codebase index ===
CODEBASE_INDEX_MAX_FILES=5000
CODEBASE_INDEX_MAX_FILE_KB=200

# === Plan/Act dual-mode (IM gateway) ===
# When true, after the clarifier accepts a requirement we generate a short
# execution plan and push it to the IM user, waiting for approval
# ("通过" / "approve" / "开干") before actually starting the pipeline.
# When false (default), the pipeline kicks off immediately.
GATEWAY_PLAN_MODE=false

# === Gateway: Feishu (Lark) ===
# 开放平台 → 自建应用 → 凭证与基础信息
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 开放平台 → 事件订阅 → Verification Token
FEISHU_VERIFICATION_TOKEN=
# 开放平台 → 事件订阅 → Encrypt Key（启用加密策略后必填）
FEISHU_ENCRYPT_KEY=
# 兜底：自定义群机器人 webhook（IM API 不可用时降级使用）
FEISHU_GROUP_WEBHOOK=

# === Gateway: QQ (OneBot v11 bridge) ===
# OneBot 桥（NapCat / go-cqhttp / Lagrange）的 HTTP API base URL
QQ_BOT_ENDPOINT=http://127.0.0.1:5700
# OneBot access_token，用于入站校验和出站调用
QQ_BOT_ACCESS_TOKEN=

# === Deploy targets (按需配置) ===
VERCEL_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# === WeChat Mini Program (可选) ===
WECHAT_MP_APPID=
WECHAT_MP_SECRET=
WECHAT_MP_PRIVATE_KEY_PATH=

# === Debug ===
DEBUG=false
