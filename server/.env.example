PORT=8787
SESSION_SECRET=请替换为至少32字符随机串

# 二选一：不设 DATABASE_URL 时使用 SQLite（需 Node 22.5+ 内置 node:sqlite）
DATABASE_PATH=./data/agent-hub.sqlite

# 设置后使用 PostgreSQL（推荐生产；Node 18+ 即可跑 API，不必用 SQLite）
# DATABASE_URL=postgresql://user:pass@localhost:5432/agenthub

# OpenAI 兼容 Chat Completions 完整 URL
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# 注意：当前 Node server 仍直接读取 LLM_*，不会自动识别
# ANTHROPIC_BASE_URL / ANTHROPIC_AUTH_TOKEN / ANTHROPIC_MODEL 这组别名。
# 如果运行的是 server/index.mjs，请继续填写上面的 LLM_*。

# 首次启动时若数据库无用户，将创建管理员（生产务必修改密码）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# 仅 HTTPS 生产且 Cookie 需 Secure 时设为 true
# COOKIE_SECURE=true

# ─── AI 军团流水线 ───

# 飞书自建应用凭证（开放平台 → 创建应用 → 凭证与基础信息）
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_VERIFICATION_TOKEN=xxx
# FEISHU_ENCRYPT_KEY=xxx

# QQ 机器人（OneBot v11 HTTP 上报；go-cqhttp / NapCat 等）
# QQ_BOT_ENDPOINT=http://127.0.0.1:5700
# QQ_BOT_SECRET=
