# OpenClaw / pipeline gateway：须与后端 PIPELINE_API_KEY 一致。本地 dev 可只设 PIPELINE_API_KEY，
# vite 会将其注入为 VITE_PIPELINE_API_KEY；静态部署请显式设置 VITE_PIPELINE_API_KEY。
# PIPELINE_API_KEY=
# VITE_PIPELINE_API_KEY=

# 生产构建时设为 true，且部署时配置与 Vite 相同的 /api/proxy/* 反向代理，请求将走同源路径
# VITE_USE_RELATIVE_PROXY=true

# 企业模式（需同时运行 server/index.mjs）；详见 README 与 .env.enterprise.example
# VITE_ENTERPRISE=true
# VITE_API_BASE=/api/hub

# 飞书自建应用验证（pnpm verify:feishu）；建议写入 .env.local 勿提交仓库
# FEISHU_APP_ID=cli_xxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
